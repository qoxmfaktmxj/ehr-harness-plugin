{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/db-read-only.sh\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/vcs-no-commit.sh\"",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
